{
  "functions": [
    {
      "source": "backend",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "src/__tests__",
        "jest.config.ts",
        ".env.test"
      ],
      "predeploy": [
        "cd shared && npm run build && cd ..",
        "rm -rf backend/_shared && mkdir -p backend/_shared && cp -r shared/dist shared/package.json backend/_shared/",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
