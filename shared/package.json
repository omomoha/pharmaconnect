{
  "name": "@pharmaconnect/shared",
  "version": "1.0.0",
  "description": "Shared types, constants, and validators for PharmaConnect marketplace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/types/index.js": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./dist/constants/index.js": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./dist/*": {
      "default": "./dist/*"
    }
  },
  "keywords": [
    "pharmacy",
    "marketplace",
    "types",
    "validators"
  ],
  "author": "",
  "license": "MIT"
}
