{
  "name": "@pharmaconnect/backend",
  "version": "1.0.0",
  "description": "PharmaConnect Backend - Firebase Admin SDK + Express.js",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:seed": "ts-node src/scripts/seed.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "ioredis": "^5.3.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "morgan": "^1.10.0",
    "jsonwebtoken": "^9.1.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "@pharmaconnect/shared": "file:../shared"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/compression": "^1.7.5",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0"
  }
}
