rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check user role from custom claims
    function hasRole(role) {
      return request.auth != null && request.auth.token.role == role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return hasRole('platform_admin');
    }

    function isSupportAdmin() {
      return hasRole('support_admin');
    }

    function isPharmacyAdmin() {
      return hasRole('pharmacy_admin');
    }

    function isDeliveryAdmin() {
      return hasRole('delivery_admin');
    }

    function isCustomer() {
      return hasRole('customer');
    }

    function isDeliveryProvider() {
      return hasRole('delivery_provider');
    }

    // ========== USERS ==========
    // Users can read and write their own profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    // ========== PHARMACIES ==========
    // Pharmacies are public read (non-sensitive data)
    match /pharmacies/{pharmacyId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated() && isPharmacyAdmin();
      allow update: if isAuthenticated() && (isPharmacyAdmin() || isAdmin());
      allow delete: if isAdmin();

      // Pharmacy can only update their own pharmacy profile
      match /pharmacies/{document=**} {
        allow write: if isAuthenticated() && (request.resource.data.adminId == request.auth.uid || isAdmin());
      }
    }

    // ========== PHARMACY PRODUCTS ==========
    // Products are public read, pharmacy admins can write their own products
    match /pharmacy_products/{productId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated() && isPharmacyAdmin();
      allow update: if isAuthenticated() && isPharmacyAdmin() && resource.data.pharmacyId == request.auth.uid || isAdmin();
      allow delete: if isAuthenticated() && isPharmacyAdmin() && resource.data.pharmacyId == request.auth.uid || isAdmin();
    }

    // ========== DRUG CATALOG ==========
    // Drug catalog (OTC drugs whitelist) - public read, platform_admin only write
    match /drug_catalog/{drugId} {
      allow read: if true; // Public read
      allow write: if isAdmin();
    }

    // ========== ORDERS ==========
    // Customers can read their own orders
    // Pharmacies can read orders for their products
    // Admins can read all orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.pharmacyId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isCustomer();
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.pharmacyId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();

      // ===== ORDER ITEMS =====
      match /items/{itemId} {
        allow read: if parent.read;
        allow write: if parent.write;
      }
    }

    // ========== DELIVERY PROVIDERS ==========
    // Delivery providers can read their own info
    // Platform admins can manage all delivery providers
    match /delivery_providers/{providerId} {
      allow read: if isAuthenticated() && (request.auth.uid == providerId || isAdmin() || isDeliveryAdmin());
      allow create: if isAuthenticated() && isDeliveryAdmin();
      allow update: if isAuthenticated() && (request.auth.uid == providerId || isAdmin() || isDeliveryAdmin());
      allow delete: if isAdmin();
    }

    // ========== DELIVERY ASSIGNMENTS ==========
    // Delivery providers can read their assigned deliveries
    // Customers can read assignments for their orders
    // Admins can read all assignments
    match /delivery_assignments/{assignmentId} {
      allow read: if isAuthenticated() && (
        resource.data.deliveryProviderId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && (isPharmacyAdmin() || isAdmin());
      allow update: if isAuthenticated() && (
        resource.data.deliveryProviderId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ========== CONVERSATIONS ==========
    // Conversation participants can read and write their conversations
    // Valid participants: customer, pharmacy admin, delivery provider
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        isAdmin()
      );
      allow delete: if isAdmin();

      // ===== MESSAGES =====
      match /messages/{messageId} {
        allow read: if parent.read;
        allow create: if parent.read && isAuthenticated();
        allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      }
    }

    // ========== FLAGGED ALERTS ==========
    // Platform admins and support admins only
    match /flagged_alerts/{alertId} {
      allow read: if isAdmin() || isSupportAdmin();
      allow write: if isAdmin();
    }

    // ========== REVIEWS ==========
    // Reviews are public read
    // Authenticated users can create reviews
    match /reviews/{reviewId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
    }

    // ========== NOTIFICATIONS ==========
    // Users can read their own notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ========== AUDIT LOGS ==========
    // Platform admins only
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ========== DEFAULT DENY ==========
    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
